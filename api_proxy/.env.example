# ComfyUI API Proxy Configuration
# Copy this to .env (or let it auto-generate on first run)

# API key for authentication (auto-generated if not set)
API_KEY=your-secret-api-key-here

# ComfyUI backend
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# Proxy server
PROXY_HOST=127.0.0.1
PROXY_PORT=8189

# Rate limiting (per IP)
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_BURST=3

# Validation
MAX_WORKFLOW_SIZE=524288
MAX_NODE_COUNT=200

# Logging
LOG_LEVEL=INFO
